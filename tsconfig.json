{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "resolveJsonModule": true,
    "paths": {
      "#flowcord": ["./libs/pokeSandbox/libs/flowcord/src/index.ts"],
      "#flowcord/*": ["./libs/pokeSandbox/libs/flowcord/src/*"]
    }
  },
  "include": ["src/**/*", "libs/pokeSandbox/libs/flowcord/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
